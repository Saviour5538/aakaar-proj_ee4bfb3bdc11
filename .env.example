# Backend configuration
DATABASE_URL=postgresql://<username>:<password>@<host>:<port>/<database>
# Connection string for the PostgreSQL database

JWT_SECRET=<random_secret>
# Secret key used for signing JWT tokens

PORT=8000
# Port on which the backend server will run

# Frontend configuration
VITE_API_URL=http://localhost:8000
# API URL for the frontend to communicate with the backend

# PostgreSQL configuration
POSTGRES_USER=<username>
# Username for the PostgreSQL database

POSTGRES_PASSWORD=<password>
# Password for the PostgreSQL database

POSTGRES_DB=<database>
# Name of the PostgreSQL database

POSTGRES_HOST=pgvector
# Hostname of the PostgreSQL service in docker-compose

POSTGRES_PORT=5432
# Port on which the PostgreSQL service is exposed

# OpenAI API configuration
OPENAI_API_KEY=<your_openai_api_key>
# API key for accessing OpenAI services

# Anthropic API configuration
ANTHROPIC_API_KEY=<your_anthropic_api_key>
# API key for accessing Anthropic services

# Pinecone API configuration
PINECONE_API_KEY=<your_pinecone_api_key>
# API key for accessing Pinecone services